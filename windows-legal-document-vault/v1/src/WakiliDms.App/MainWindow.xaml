<Window x:Class="WakiliDms.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Legal Document Vault"
        Width="1040"
        Height="720"
        MinWidth="840"
        MinHeight="560">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#111827" Padding="24,18">
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Subtitle}"
                           Foreground="#CBD5E1"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24"
              Visibility="{Binding IsSetupRequired, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Padding="20"
                    CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                    <TextBlock Text="First-run setup"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#111827" />
                    <TextBlock Text="Create the local-first settings needed before the encrypted vault module starts."
                               TextWrapping="Wrap"
                               Foreground="#374151"
                               Margin="0,10,0,0" />

                    <TextBlock Text="Firm name" Margin="0,18,0,4" />
                    <TextBox AutomationProperties.AutomationId="SetupFirmName"
                             Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Primary user" Margin="0,12,0,4" />
                    <TextBox AutomationProperties.AutomationId="SetupPrimaryUser"
                             Text="{Binding PrimaryUser, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Device nickname" Margin="0,12,0,4" />
                    <TextBox AutomationProperties.AutomationId="SetupDeviceNickname"
                             Text="{Binding DeviceNickname, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="License key" Margin="0,12,0,4" />
                    <TextBox AutomationProperties.AutomationId="SetupLicenseKey"
                             Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Vault path" Margin="0,12,0,4" />
                    <TextBox AutomationProperties.AutomationId="SetupVaultPath"
                             Text="{Binding VaultPath, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Watched scan folder" Margin="0,12,0,4" />
                    <TextBox AutomationProperties.AutomationId="SetupScanFolderPath"
                             Text="{Binding ScanFolderPath, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Backup target folder" Margin="0,12,0,4" />
                    <TextBox AutomationProperties.AutomationId="SetupBackupTargetPath"
                             Text="{Binding BackupTargetPath, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Recovery key" Margin="0,12,0,4" />
                    <TextBox AutomationProperties.AutomationId="SetupRecoveryKey"
                             Text="{Binding SetupRecoveryKey, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Content="I have saved the recovery key details for this vault."
                              AutomationProperties.AutomationId="SetupRecoveryKeyConfirmed"
                              IsChecked="{Binding RecoveryKeyConfirmed}"
                              Margin="0,16,0,0" />

                    <Button Content="Complete setup"
                            AutomationProperties.AutomationId="CompleteSetupButton"
                            Command="{Binding CompleteSetupCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,18,0,0" />

                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Foreground="#B45309"
                               Margin="0,14,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Padding="20"
                    Margin="20,0,0,0"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Next modules"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#111827" />
                    <TextBlock Text="After setup is persisted, the next slice creates and unlocks the encrypted vault."
                               TextWrapping="Wrap"
                               Foreground="#374151"
                               Margin="0,10,0,10" />
                    <ItemsControl ItemsSource="{Binding NextModules}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="#374151"
                                           Margin="0,0,0,6" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="24"
              Visibility="{Binding IsSetupComplete, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Padding="20"
                    CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Home"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#111827" />
                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Foreground="#374151"
                               Margin="0,10,0,0" />

                    <TextBlock Text="Vault path" FontWeight="SemiBold" Margin="0,18,0,4" />
                    <TextBlock Text="{Binding VaultPath}" TextWrapping="Wrap" Foreground="#374151" />

                    <TextBlock Text="Watched scan folder" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <TextBlock Text="{Binding ScanFolderPath}" TextWrapping="Wrap" Foreground="#374151" />

                    <TextBlock Text="Backup target" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <TextBlock Text="{Binding BackupTargetPath}" TextWrapping="Wrap" Foreground="#374151" />

                    <TextBlock Text="Installation ID" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <TextBlock Text="{Binding InstallationId}" TextWrapping="Wrap" Foreground="#374151" />

                    <TextBlock Text="{Binding LicenseStatusText}" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <TextBlock Text="{Binding DeviceNickname}" TextWrapping="Wrap" Foreground="#374151" />

                    <TextBlock Text="Create matter" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,8" />
                    <TextBlock Text="Matter name" Margin="0,0,0,4" />
                    <TextBox AutomationProperties.AutomationId="NewMatterName"
                             Text="{Binding NewMatterName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Client name" Margin="0,10,0,4" />
                    <TextBox AutomationProperties.AutomationId="NewMatterClientName"
                             Text="{Binding NewMatterClientName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Court case number" Margin="0,10,0,4" />
                    <TextBox AutomationProperties.AutomationId="NewMatterCourtCaseNumber"
                             Text="{Binding NewMatterCourtCaseNumber, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Content="Create matter"
                            AutomationProperties.AutomationId="CreateMatterButton"
                            Command="{Binding CreateMatterCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,14,0,0" />

                    <TextBlock Text="Import document" FontSize="16" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <TextBlock Text="Source file path" Margin="0,0,0,4" />
                    <TextBox AutomationProperties.AutomationId="ImportSourceFilePath"
                             Text="{Binding ImportSourceFilePath, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Recovery key" Margin="0,10,0,4" />
                    <TextBox AutomationProperties.AutomationId="ImportRecoveryKey"
                             Text="{Binding ImportRecoveryKey, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Content="Import selected matter document"
                            AutomationProperties.AutomationId="ImportMatterDocumentButton"
                            Command="{Binding ImportDocumentCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,14,0,0" />

                    <TextBlock Text="Scan inbox" FontSize="16" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <Button Content="Refresh watched scan folder"
                            AutomationProperties.AutomationId="RefreshScanFolderButton"
                            Command="{Binding RefreshScanFolderCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,0,0,0" />

                    <Button Content="Import selected scan"
                            AutomationProperties.AutomationId="ImportSelectedScanButton"
                            Command="{Binding ImportSelectedScanCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />

                    <TextBlock Text="Classify selected document" FontSize="16" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <TextBlock Text="Document type" Margin="0,0,0,4" />
                    <ComboBox AutomationProperties.AutomationId="DocumentTypeCombo"
                              ItemsSource="{Binding DocumentTypeOptions}"
                              SelectedItem="{Binding SelectedDocumentType}" />

                    <TextBlock Text="Document status" Margin="0,10,0,4" />
                    <ComboBox AutomationProperties.AutomationId="DocumentStatusCombo"
                              ItemsSource="{Binding DocumentStatusOptions}"
                              SelectedItem="{Binding SelectedDocumentStatus}" />

                    <Button Content="Update classification"
                            AutomationProperties.AutomationId="UpdateClassificationButton"
                            Command="{Binding UpdateDocumentClassificationCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,14,0,0" />

                    <TextBlock Text="OCR and search" FontSize="16" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <Button Content="Index selected document"
                            AutomationProperties.AutomationId="IndexSelectedDocumentButton"
                            Command="{Binding IndexSelectedDocumentCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8" />

                    <TextBlock Text="Search this matter" Margin="0,14,0,4" />
                    <TextBox AutomationProperties.AutomationId="SearchQuery"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Search"
                            AutomationProperties.AutomationId="SearchMatterButton"
                            Command="{Binding SearchMatterCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />

                    <TextBlock Text="Filing pack" FontSize="16" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <TextBlock Text="Export root folder" Margin="0,0,0,4" />
                    <TextBox AutomationProperties.AutomationId="FilingPackExportRootPath"
                             Text="{Binding FilingPackExportRootPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Export matter filing pack"
                            AutomationProperties.AutomationId="ExportFilingPackButton"
                            Command="{Binding ExportFilingPackCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />

                    <TextBlock Text="Capture receipt or court output" FontSize="16" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <TextBlock Text="Source file path" Margin="0,0,0,4" />
                    <TextBox AutomationProperties.AutomationId="CourtOutputSourceFilePath"
                             Text="{Binding CourtOutputSourceFilePath, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Output type" Margin="0,10,0,4" />
                    <ComboBox AutomationProperties.AutomationId="CourtOutputTypeCombo"
                              ItemsSource="{Binding CourtOutputTypeOptions}"
                              SelectedItem="{Binding SelectedCourtOutputType}" />

                    <Button Content="Capture to selected matter"
                            AutomationProperties.AutomationId="CaptureCourtOutputButton"
                            Command="{Binding CaptureCourtOutputCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />

                    <TextBlock Text="Backup and restore drill" FontSize="16" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <TextBlock Text="Recovery key" Margin="0,0,0,4" />
                    <TextBox AutomationProperties.AutomationId="BackupRecoveryKey"
                             Text="{Binding BackupRecoveryKey, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Run backup and restore drill"
                            AutomationProperties.AutomationId="RunBackupButton"
                            Command="{Binding RunBackupCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8" />
                    <Button Content="Refresh local backups"
                            AutomationProperties.AutomationId="RefreshLocalBackupsButton"
                            Command="{Binding RefreshLocalBackupsCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                    <TextBlock Text="Local restore workspace folder" Margin="0,14,0,4" />
                    <TextBox AutomationProperties.AutomationId="LocalRestoreTargetPath"
                             Text="{Binding LocalRestoreTargetPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Run selected local restore workspace"
                            AutomationProperties.AutomationId="RestoreSelectedLocalBackupButton"
                            Command="{Binding RestoreSelectedLocalBackupCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                    <Button Content="Delete selected local backup"
                            AutomationProperties.AutomationId="DeleteSelectedLocalBackupButton"
                            Command="{Binding DeleteSelectedLocalBackupCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                    <TextBlock Text="Local backup retention"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,28,0,8" />
                    <TextBlock Text="Keep latest snapshot count" Margin="0,0,0,4" />
                    <TextBox AutomationProperties.AutomationId="RetentionKeepLatestCount"
                             Text="{Binding RetentionKeepLatestCount, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Delete snapshots older than days" Margin="0,10,0,4" />
                    <TextBox AutomationProperties.AutomationId="RetentionDeleteOlderThanDays"
                             Text="{Binding RetentionDeleteOlderThanDays, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Preview local backup cleanup"
                            AutomationProperties.AutomationId="PreviewLocalBackupRetentionButton"
                            Command="{Binding PreviewLocalBackupRetentionCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                    <Button Content="Apply local backup cleanup"
                            AutomationProperties.AutomationId="ApplyLocalBackupRetentionButton"
                            Command="{Binding ApplyLocalBackupRetentionCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                    <TextBlock Text="{Binding RetentionPreviewText}"
                               AutomationProperties.AutomationId="RetentionPreviewText"
                               TextWrapping="Wrap"
                               Foreground="#374151"
                               Margin="0,10,0,0" />
                    <TextBlock Text="External backup from another machine"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,28,0,8" />
                    <TextBlock Text="External backup folder" Margin="0,0,0,4" />
                    <TextBox AutomationProperties.AutomationId="ExternalBackupDirectoryPath"
                             Text="{Binding ExternalBackupDirectoryPath, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="External restore workspace folder" Margin="0,14,0,4" />
                    <TextBox AutomationProperties.AutomationId="ExternalRestoreTargetPath"
                             Text="{Binding ExternalRestoreTargetPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Verify external backup restore"
                            AutomationProperties.AutomationId="VerifyExternalBackupButton"
                            Command="{Binding VerifyExternalBackupCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />

                    <TextBlock Text="Cloud backup"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,28,0,8" />
                    <TextBlock Text="{Binding CloudBackupStatusText}"
                               Foreground="#374151"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Local provider folder" Margin="0,0,0,4" />
                    <TextBox AutomationProperties.AutomationId="CloudBackupProviderPath"
                             Text="{Binding CloudBackupProviderPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Enable cloud backup"
                            AutomationProperties.AutomationId="EnableCloudBackupButton"
                            Command="{Binding EnableCloudBackupCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                    <Button Content="Upload encrypted cloud backup"
                            AutomationProperties.AutomationId="UploadCloudBackupButton"
                            Command="{Binding UploadCloudBackupCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                    <Button Content="Refresh cloud backups"
                            AutomationProperties.AutomationId="RefreshCloudBackupsButton"
                            Command="{Binding RefreshCloudBackupsCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                    <TextBlock Text="Cloud restore target folder" Margin="0,14,0,4" />
                    <TextBox AutomationProperties.AutomationId="CloudRestoreTargetPath"
                             Text="{Binding CloudRestoreTargetPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Run selected cloud restore drill"
                            AutomationProperties.AutomationId="RestoreSelectedCloudBackupButton"
                            Command="{Binding RestoreSelectedCloudBackupCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                    <Button Content="Delete selected cloud backup"
                            AutomationProperties.AutomationId="DeleteSelectedCloudBackupButton"
                            Command="{Binding DeleteSelectedCloudBackupCommand}"
                            HorizontalAlignment="Left"
                            Padding="18,8"
                            Margin="0,10,0,0" />
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Padding="20"
                    Margin="20,0,0,0"
                    CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Current status"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock Text="Setup, encrypted vault, matter management, document import, scan inbox, OCR/search, filing pack, court-output capture, and backup checks are active."
                                   TextWrapping="Wrap"
                                   Foreground="#374151"
                                   Margin="0,10,0,0" />
                        <TextBlock Text="{Binding BackupHealthStatus}"
                                   AutomationProperties.AutomationId="BackupHealthStatus"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,16,0,0" />
                        <TextBlock Text="{Binding BackupSnapshotCountsText}"
                                   AutomationProperties.AutomationId="BackupSnapshotCountsText"
                                   TextWrapping="Wrap"
                                   Foreground="#374151"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding LastLocalBackupText}"
                                   AutomationProperties.AutomationId="LastLocalBackupText"
                                   TextWrapping="Wrap"
                                   Foreground="#374151"
                                   Margin="0,2,0,0" />
                        <TextBlock Text="{Binding LastCloudBackupText}"
                                   AutomationProperties.AutomationId="LastCloudBackupText"
                                   TextWrapping="Wrap"
                                   Foreground="#374151"
                                   Margin="0,2,0,0" />
                        <TextBlock Text="{Binding LastRestoreReportText}"
                                   AutomationProperties.AutomationId="LastRestoreReportText"
                                   TextWrapping="Wrap"
                                   Foreground="#374151"
                                   Margin="0,2,0,0" />
                        <Button Content="Copy latest restore report path"
                                AutomationProperties.AutomationId="CopyLastRestoreReportPathButton"
                                Command="{Binding CopyLastRestoreReportPathCommand}"
                                HorizontalAlignment="Left"
                                Padding="12,6"
                                Margin="0,8,0,0" />
                        <TextBlock Text="Restore report export folder" Margin="0,10,0,4" />
                        <TextBox AutomationProperties.AutomationId="RestoreReportExportFolderPath"
                                 Text="{Binding RestoreReportExportFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Export latest restore report"
                                AutomationProperties.AutomationId="ExportLastRestoreReportButton"
                                Command="{Binding ExportLastRestoreReportCommand}"
                                HorizontalAlignment="Left"
                                Padding="12,6"
                                Margin="0,8,0,0" />

                        <TextBlock Text="Matters"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,20,0,8" />
                        <ListBox AutomationProperties.AutomationId="MattersList"
                                 ItemsSource="{Binding Matters}"
                                 SelectedItem="{Binding SelectedMatter}"
                                 BorderThickness="0"
                                 MaxHeight="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,8"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#111827" />
                                            <TextBlock Text="{Binding ClientName}" Foreground="#374151" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding CourtCaseNumber}" Foreground="#6B7280" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding UpdatedAt}" Foreground="#6B7280" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Pending scans"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,20,0,8" />
                        <ListBox AutomationProperties.AutomationId="ScanInboxList"
                                 ItemsSource="{Binding ScanInbox}"
                                 SelectedItem="{Binding SelectedScan}"
                                 BorderThickness="0"
                                 MaxHeight="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,8"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OriginalFileName}" FontWeight="SemiBold" Foreground="#111827" />
                                            <TextBlock Text="{Binding ByteLength}" Foreground="#6B7280" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding DetectedAt}" Foreground="#6B7280" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Matter documents"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,20,0,8" />
                        <ListBox AutomationProperties.AutomationId="DocumentsList"
                                 ItemsSource="{Binding Documents}"
                                 SelectedItem="{Binding SelectedDocument}"
                                 BorderThickness="0"
                                 MaxHeight="220">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,8"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OriginalFileName}" FontWeight="SemiBold" Foreground="#111827" />
                                            <TextBlock Text="{Binding DocumentType}" Foreground="#374151" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Status}" Foreground="#374151" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding ByteLength}" Foreground="#6B7280" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding ImportedAt}" Foreground="#6B7280" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Document versions"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,20,0,8" />
                        <ItemsControl ItemsSource="{Binding DocumentVersions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,8"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding VersionNumber}" FontWeight="SemiBold" Foreground="#111827" />
                                            <TextBlock Text="{Binding OriginalFileName}" Foreground="#374151" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Status}" Foreground="#6B7280" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding CreatedAt}" Foreground="#6B7280" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding Notes}" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Search results"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,20,0,8" />
                        <ItemsControl ItemsSource="{Binding SearchResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,8"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OriginalFileName}" FontWeight="SemiBold" Foreground="#111827" />
                                            <TextBlock Text="{Binding Snippet}" Foreground="#374151" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Local backups"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,20,0,8" />
                        <ListBox AutomationProperties.AutomationId="LocalBackupsList"
                                 ItemsSource="{Binding LocalBackupSnapshots}"
                                 SelectedItem="{Binding SelectedLocalBackupSnapshot}"
                                 BorderThickness="0"
                                 MaxHeight="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,8"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SnapshotId}" FontWeight="SemiBold" Foreground="#111827" />
                                            <TextBlock Text="{Binding CreatedAt}" Foreground="#374151" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding FileCount}" Foreground="#6B7280" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding ByteLength}" Foreground="#6B7280" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Cloud backups"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,20,0,8" />
                        <ListBox AutomationProperties.AutomationId="CloudBackupsList"
                                 ItemsSource="{Binding CloudBackupSnapshots}"
                                 SelectedItem="{Binding SelectedCloudBackupSnapshot}"
                                 BorderThickness="0"
                                 MaxHeight="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,8"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SnapshotId}" FontWeight="SemiBold" Foreground="#111827" />
                                            <TextBlock Text="{Binding CreatedAt}" Foreground="#374151" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding EncryptedByteLength}" Foreground="#6B7280" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding Status}" Foreground="#6B7280" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
